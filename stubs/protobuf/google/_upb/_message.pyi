from typing import Any, ClassVar, final
from typing_extensions import Self, disjoint_base

from google.protobuf.descriptor_pb2 import (
    EnumOptions,
    EnumValueOptions,
    FieldOptions,
    FileOptions,
    MessageOptions,
    MethodOptions,
    OneofOptions,
    ServiceOptions,
)

default_pool: DescriptorPool

@final
class Arena: ...

@final
class Descriptor:
    containing_type: Descriptor | None
    enum_types: Any
